{
    "name": "sitenavigator-server",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "bin": "build/server.cjs",
    "description": "Local crawler/index backend for SiteNavigator (Node 22/24 LTS compatible)",
    "engines": {
      "node": ">=22 <25"
    },
    "scripts": {
      "dev": "node src/server.js",
      "dev:local": "node src/server.js --port=8788",
      "build": "node scripts/prepare-client.mjs && node scripts/bundle-server.mjs",
      "build:ketch": "node scripts/build-ketch.mjs",
      "build:portable": "node scripts/build-ketch.mjs && node scripts/prepare-client.mjs && node scripts/bundle-server.mjs && npx @yao-pkg/pkg . --compress GZip --output ../dist/sitenavigator-core.exe",
      "start": "node src/server.js",
      "package:portable:core": "npx @yao-pkg/pkg . --compress GZip --output ../dist/sitenavigator-core.exe",
      "test": "node --test",
      "test:coverage": "c8 --reporter=text-summary --reporter=lcov --include=src/recency.js node --test",
      "test:coverage:check": "c8 --check-coverage --lines 90 --functions 90 --branches 85 --statements 90 --include=src/recency.js node --test",
      "index:reset": "node scripts/reset-index.mjs"
    },
    "dependencies": {
      "cheerio": "^1.2.0",
      "cors": "^2.8.5",
      "express": "^4.22.1"
    },
    "devDependencies": {
      "@yao-pkg/pkg": "^6.6.0",
      "c8": "^10.1.3",
      "esbuild": "^0.25.9"
    },
    "pkg": {
      "scripts": [
        "build/server.cjs"
      ],
      "assets": [
        "public/**/*",
        "data/**/*",
        "vendor/ketch/**/*"
      ],
      "targets": [
        "node22-win-x64"
      ],
      "outputPath": "../dist"
    }
  }