{
  "name": "client",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=22 <25"
  },
  "scripts": {
    "dev": "vite",
    "dev:local": "vite --host 127.0.0.1 --port 4173",
    "dev:e2e": "vite --host 127.0.0.1 --port 4173 --mode e2e",
    "build": "vite build",
    "lint": "eslint .",
    "test:unit": "node --test tests/unit/**/*.test.mjs",
    "test:coverage": "c8 --reporter=text-summary --reporter=lcov --include=src/features/sitenavigator/facets.js --include=src/features/sitenavigator/vendorSections.js node --test tests/unit/**/*.test.mjs",
    "test:coverage:check": "c8 --check-coverage --lines 80 --functions 80 --branches 70 --statements 80 --include=src/features/sitenavigator/facets.js --include=src/features/sitenavigator/vendorSections.js node --test tests/unit/**/*.test.mjs",
    "preview": "vite preview",
    "qa:keyboard": "node scripts/keyboard-walkthrough.mjs",
    "qa:keyboard:e2e": "playwright test tests/keyboard-walkthrough.spec.js",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "lucide-react": "^0.577.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.1",
    "c8": "^10.1.3",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.17",
    "vite": "^8.0.0"
  }
}
